{
  "name": "@freeusd/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cursor SDK harness for FreeUSD parity-driven development",
  "bin": {
    "freeusd-agent": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "agent": "tsx src/cli.ts",
    "agent:parity": "tsx src/cli.ts parity",
    "agent:fix-ctest": "tsx src/cli.ts fix-ctest",
    "agent:resume": "tsx src/cli.ts resume",
    "agent:cloud-parity": "tsx src/cli.ts cloud-parity"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.13"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
