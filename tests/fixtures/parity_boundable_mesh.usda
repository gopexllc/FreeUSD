#usda 1.0
(
    defaultPrim = "World"
    doc = "Mesh point bounds + xform parent aggregation for engine residency."
)

def Xform "World"
{
    def Xform "Group"
    {
        double3 xformOp:translate = (10, 20, 30)
        uniform token[] xformOpOrder = ["xformOp:translate"]

        def Mesh "Quad"
        {
            point3f[] points = [(0, 0, 0), (4, 0, 0), (4, 3, 0), (0, 3, 0)]
            int[] faceVertexCounts = [4]
            int[] faceVertexIndices = [0, 1, 2, 3]
        }
    }
}
