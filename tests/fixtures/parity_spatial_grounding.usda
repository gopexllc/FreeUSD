#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1.0
    upAxis = "Y"
)

def Xform "World"
{
    def Xform "Kitchen"
    {
        double3 xformOp:translate = (10, 0, 0)
        token[] xformOpOrder = [xformOp:translate]

        def Xform "CupBlue"
        (
            prepend apiSchemas = ["PhysicsRigidBodyAPI"]
        )
        {
            double size = 1.0
            float physics:mass = 0.35
            double3 xformOp:translate = (1, 2, 3)
            double3 xformOp:scale = (0.5, 1.5, 0.25)
            token[] xformOpOrder = [xformOp:translate, xformOp:scale]
            token[] semantics:labels:somaHome = ["Crockery", "DesignedContainer"]
            token[] semantics:labels:engine = ["pickup", "container"]
        }

        def Xform "PlateGreen"
        {
            double size = 2.0
            double3 xformOp:translate = (4, 0, 0)
            token[] xformOpOrder = [xformOp:translate]
        }

        def Xform "Stove"
        {
            double size = 3.0
            double3 xformOp:translate = (0, 0, 5)
            token[] xformOpOrder = [xformOp:translate]
        }
    }
}
