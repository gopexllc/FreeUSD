#usda 1.0
(
    defaultPrim = "World"
)

def Xform "World"
{
    class "KindClass" (
        kind = "assembly"
    )
    {
    }

    def "RefHost"
    (
        prepend references = @./parity_kind_active_ref.usda@
    )
    {
    }

    def "PayloadHost"
    (
        prepend payload = @./parity_kind_active_payload.usda@
    )
    {
    }

    def "InheritHost"
    (
        prepend inherits = </World/KindClass>
    )
    {
    }
}
