#usda 1.0
(
    defaultPrim = "World"
)

def Xform "World"
{
    class "CollisionClass"
    (
        prepend apiSchemas = ["PhysicsCollisionAPI"]
    )
    {
        bool physics:collisionEnabled = 0
    }

    def "Collider"
    (
        prepend inherits = </World/CollisionClass>
    )
    {
    }
}
