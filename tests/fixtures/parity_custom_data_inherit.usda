#usda 1.0
(
    defaultPrim = "World"
)

def Xform "World"
{
    class "BaseClass"
    (
        customData = {
            string role = "base"
            int priority = 1
        }
    )
    {
    }

    def "Host"
    (
        prepend inherits = </World/BaseClass>
        customData = {
            int priority = 9
        }
    )
    {
        double hostOnly = 3.0
    }
}
