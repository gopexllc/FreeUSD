#usda 1.0
(
    defaultPrim = "World"
)

# Preview surface with diffuseColor connected to UsdUVTexture inputs:file

def Xform "World"
{
    def Scope "Looks"
    {
        def Material "Material"
        {
            token outputs:surface.connect = </World/Looks/Material/PreviewSurface.outputs:surface>

            def Shader "PreviewSurface"
            {
                token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor.connect = </World/Looks/Material/diffuseTexture.outputs:rgb>
            }

            def Shader "diffuseTexture"
            {
                token info:id = "UsdUVTexture"
                asset inputs:file = @textures/albedo.png@
            }
        }
    }
}
