#usda 1.0
(
    defaultPrim = "World"
)

def Xform "World"
{
    def "RefHost"
    (
        prepend references = @./parity_custom_data_ref.usda@
        customData = {
            int priority = 9,
        }
    )
    {
    }

    def "PayloadHost"
    (
        prepend payload = @./parity_custom_data_payload.usda@
    )
    {
    }
}
