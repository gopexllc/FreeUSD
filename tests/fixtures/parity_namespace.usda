#usda 1.0
(
    relocates = {
        </Library/Source>: </Library/Published>,
    }
    prefixSubstitutions = {
        "/Assets": "/ResolvedAssets",
    }
)

def Xform "Library"
{
    def "Source"
    (
        prepend references = @./parity_namespace_ref.usda@
        prepend payload = @./parity_namespace_payload.usda@
    )
    {
        double radius = 2.0
    }
}
