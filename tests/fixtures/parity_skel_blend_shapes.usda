#usda 1.0
(
    defaultPrim = "World"
)

# glTF mapping (parity_skel_blend_shapes.usda):
# morph target POSITION deltas  -> BlendShape offsets
# mesh.weights                  -> blendShapeWeights on geom
# skel:blendShapes + skel:blendShapeTargets -> token map + BlendShape prims

def Xform "World"
{
    def Mesh "Face"
    {
        point3f[] points = [(0, 0, 0), (1, 0, 0)]

        token[] skel:blendShapes = ["Smile", "Blink"]
        rel skel:blendShapeTargets = [</World/BlendShapes/Smile>, </World/BlendShapes/Blink>]

        float[] blendShapeWeights = [0, 0]
        float[] blendShapeWeights.timeSamples = {
            0: [0, 0],
            1: [1, 0.5]
        }
    }

    def Scope "BlendShapes"
    {
        def BlendShape "Smile"
        {
            point3f[] offsets = [(0, 1, 0), (0, 1, 0)]
        }

        def BlendShape "Blink"
        {
            point3f[] offsets = [(0, 0, 1), (0, 0, 0)]
        }
    }
}
