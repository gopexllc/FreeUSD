#usda 1.0
(
    defaultPrim = "World"
)

# Blend shapes / morph targets (parity_skel_blend_shapes.usda):
# skel:blendShapes + skel:blendShapeTargets  -> mesh morph slots (glTF mesh.weights)
# blendShapeWeights                          -> per-target weights on geom
# BlendShape.offsets                         -> POSITION deltas (dense or via pointIndices)

def Xform "World"
{
    def Mesh "Face"
    {
        point3f[] points = [(0, 0, 0), (1, 0, 0)]
        uniform token[] skel:blendShapes = ["Smile", "Wink"]
        rel skel:blendShapeTargets = </World/BlendShapes/Smile>, </World/BlendShapes/Wink>
        float[] blendShapeWeights = [1.0, 0.0]
    }

    def Scope "BlendShapes"
    {
        def BlendShape "Smile"
        {
            point3f[] offsets = [(0, 1, 0), (0, 1, 0)]
        }

        def BlendShape "Wink"
        {
            int[] pointIndices = [1]
            point3f[] offsets = [(0, 0.5, 0)]
        }
    }
}
